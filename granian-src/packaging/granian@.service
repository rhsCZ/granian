[Unit]
Description=Granian application server for %i
After=network.target
Wants=network-online.target
Conflicts=granian.service granian@.service

[Service]
Type=simple
User=granian
Group=granian
WorkingDirectory=/var/lib/granian
EnvironmentFile=-/etc/default/granian
ExecStart=/usr/sbin/granian-wrapper --instance %i
ExecStartPre=/usr/sbin/granian-wrapper --check --instance %i
Restart=on-failure
RestartSec=2s
StandardOutput=append:/var/log/granian/%i-supervisor.log
StandardError=append:/var/log/granian/%i-supervisor.log
RuntimeDirectory=granian
StateDirectory=granian
LogsDirectory=granian
NoNewPrivileges=true
ReadWritePaths=/var/lib/granian /var/log/granian /run/granian /etc/granian/apps-enabled

[Install]
WantedBy=multi-user.target
