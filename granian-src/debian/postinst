#!/bin/sh
set -e

case "$1" in
    configure)
        if ! getent group granian >/dev/null; then
            addgroup --system granian
        fi
        if ! getent passwd granian >/dev/null; then
            adduser \
                --system \
                --ingroup granian \
                --home /var/lib/granian \
                --no-create-home \
                --disabled-login \
                --disabled-password \
                --gecos "Granian service user" \
                granian
        fi

        install -d -o granian -g granian -m 0755 /var/log/granian

        systemctl daemon-reload

        cat <<'EOF'
granian: package installed/updated.
granian: service start/restart is not forced automatically during install/upgrade.
granian: if needed, run:
  systemctl restart granian.service
or
  systemctl restart granian@app.service
EOF
    ;;
esac

#DEBHELPER#
